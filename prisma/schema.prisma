generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              String   @id @default(cuid())
  clerkUserId     String   @unique
  heightCm        Float?
  currentWeightKg Float?
  bodyFatPct      Float?
  tdeeBase        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
